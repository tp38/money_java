@startuml "money java activités"
start
:welcome window;
repeat
    if ( menu_db ?) then (yes)
        if ( select_db ?) then (yes)
            :show_db_list;
            note
                **db list salt**
            end note
            :select_db;
            :connect_db;
        elseif ( replicate_db ? ) then (yes)
            :replicate;
        elseif ( quit ? ) then (yes)
            end
        endif
    elseif ( menu_accounts ? ) then (yes)
        :view accounts;
        note
            **accounts list salt**
        end note
        if ( click_on_account) then (yes )
            label sp_lab0
            label lab
            :view operation list;
            note
                **ops list salt**
            end note
        endif
    elseif ( menu_categories ) then (yes)
        :view categories;
        note
            **cats list salt**
        end note
        if ( click_on_category ) then (yes )
            label sp_lab2
            goto lab
        endif
    elseif ( menu_search ) then (yes)
        :search;
    elseif ( menu_help ) then (yes)

    endif
repeat while (quit?)
end
@enduml